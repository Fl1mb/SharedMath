@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Bring in all exported targets (SharedMath::SharedMath, SharedMath::LinearAlgebra, …)
include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake")

# Convenience variable: root install prefix (set by configure_package_config_file)
set_and_check(SharedMath_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")

# Make sure every required component is present
check_required_components("@PROJECT_NAME@")
